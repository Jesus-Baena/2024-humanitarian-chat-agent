# Nuxt dev/build outputs
.output
.data
.nuxt
.nitro
.cache
dist

# Node dependencies
node_modules

# Logs
logs
*.log

# Misc
.DS_Store
.fleet
.idea

# Local env files
.env
.env.*
!.env.example

# Prevent accidentally committing secrets
*secret*
*SECRET*
*key*
*KEY*
*token*
*TOKEN*
*password*
*PASSWORD*
*.key
*.pem

# ========================================
# DEPLOYMENT & INFRASTRUCTURE FILES
# ========================================
# These contain sensitive infrastructure details, API endpoints, 
# deployment procedures, and should NOT be public

# Docker Compose files (contain infrastructure config)
docker-compose*.yml
docker-compose*.yaml
!docker-compose.example.yml

# All shell scripts (deployment, diagnostics, helpers)
*.sh

# All root-level markdown files except README and LICENSE
# (These typically contain deployment/setup/debug procedures)
/*.md
!README.md
!/LICENSE.md

# Specific documentation patterns
*DEPLOYMENT*.md
*DEPLOY*.md
*SETUP*.md
*SECRETS*.md
*RUNNER*.md
*SWARM*.md
*DOCKER*.md
*REGISTRY*.md
*SECURITY*.md
*PORTAINER*.md
*MCP*.md
*AUTH*.md
*GUIDE*.md
*TESTING*.md
*FLOW*.md
*IMPLEMENTATION*.md
*EXECUTIVE*.md
*INDEX*.md
*QUICK*.md

# Documentation directories (contain infrastructure details)
/docs/
!/docs/README.md

# Diagnostic/debug files
*.html
!public/*.html
/public/test-chat.html

# Tool configuration that may contain sensitive data
/tools.yaml

# VSC
.history
